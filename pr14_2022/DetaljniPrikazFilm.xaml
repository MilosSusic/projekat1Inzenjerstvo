<Window x:Class="pr14_2022.DetaljniPrikazFilm"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:pr14_2022"
        mc:Ignorable="d"
        WindowStyle="None" Height="720" Width="1200"
        AllowsTransparency="True"
        Background="Transparent"
       MouseLeftButtonDown="Window_MouseLeftButtonDown" >
    <Canvas Width="1010" Height="1000" RenderTransformOrigin="0.5,0.5">

        <!-- POZADINA -->
        <Border Width="970" Height="690" CornerRadius="60" Canvas.Left="20" Canvas.Top="20"
            BorderBrush="#FFD700" BorderThickness="2">
            <Border.Background>
                <LinearGradientBrush StartPoint="0,0" EndPoint="0,1" Opacity="0.95">
                    <GradientStop Color="#1C1C1C" Offset="0"/>
                    <GradientStop Color="#2A2A2A" Offset="1"/>
                </LinearGradientBrush>
            </Border.Background>
        </Border>

        <!-- SADRŽAJ  -->
        <Grid Height="550" Width="906" Canvas.Left="52" Canvas.Top="60">
            <!-- Naziv filma -->
            <TextBox x:Name="textBoxNaziv" TextWrapping="Wrap" BorderThickness="0"
                 Background="Transparent" Foreground="#FFD700"
                 Margin="194,206,445,313" FontSize="20" FontFamily="Arial Black"
                 ToolTip="Naziv filma" HorizontalContentAlignment="Center"/>

            <!-- Slika filma -->
            <Image x:Name="imgSlika" Margin="194,237,530,166" Width="182" Height="150"
               ToolTip="Poster filma" Stretch="UniformToFill"/>

            <!-- Dugme zatvori -->
            <Button x:Name="btnZatvori" Content="Zatvori" Click="btnZatvori_Click"
                Margin="384,500,302,-14" FontSize="25" FontFamily="Montserrat"
                Cursor="Hand" Width="220" Height="45" ToolTip="Zatvori prozor">
                <Button.Style>
                    <Style TargetType="Button">
                        <Setter Property="Background">
                            <Setter.Value>
                                <LinearGradientBrush StartPoint="0.5,0" EndPoint="0.5,1">
                                    <GradientStop Color="Black" Offset="0"/>
                                    <GradientStop Color="#FFD700" Offset="1"/>
                                </LinearGradientBrush>
                            </Setter.Value>
                        </Setter>
                        <Style.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#FFC000"/>
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </Button.Style>
                <Button.Template>
                    <ControlTemplate TargetType="Button">
                        <Border Width="200" Height="40" CornerRadius="9" Background="{TemplateBinding Background}">
                            <ContentPresenter VerticalAlignment="Center" HorizontalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Button.Template>
            </Button>

            <!-- Opis filma -->
            <RichTextBox x:Name="richTextBoxFilms" IsReadOnly="True"
                     Margin="400,237,215,163" Width="291" Height="150"
                     Background="Yellow" BorderBrush="#FFD700" BorderThickness="1"
                     ScrollViewer.VerticalScrollBarVisibility="Visible" ToolTip="Opis filma">
                <FlowDocument>
                    <Paragraph>
                        <Run Name="RichTextBoxText" Foreground="White" FontSize="15"/>
                    </Paragraph>
                </FlowDocument>
            </RichTextBox>

            <!-- Datum dodavanja -->
            <TextBox x:Name="textBoxDatum" Background="Transparent" Foreground="#FFD700"
                 BorderThickness="0" FontSize="20" Margin="120,380 ,215,117"
                 ToolTip="Godina / datum izlaska" HorizontalContentAlignment="Center"/>

            <!--Opis filma-->
            <TextBox x:Name="textBoxBroj" TextWrapping="Wrap" Background="Transparent"
                 BorderThickness="0" FontSize="20" Margin="185,413,412,87"
                 Foreground="#FFD700" ToolTip="Žanr filma" HorizontalContentAlignment="Center"/>

            <!-- Naziv fajla -->
            <TextBox x:Name="textBoxFajl" Margin="189,454,0,0" FontSize="20"
                 TextWrapping="Wrap" Background="Transparent" Width="250" Height="31"
                 BorderThickness="0" Foreground="#FFD700" ToolTip="Naziv fajla"
                 HorizontalAlignment="Left" VerticalAlignment="Top" HorizontalContentAlignment="Center"/>
        </Grid>

        <!-- NASLOV -->
        <Label Content="PODACI O FILMU" FontSize="45" FontWeight="Bold"
           Foreground="#FFD700" Background="Black" HorizontalContentAlignment="Center"
           VerticalContentAlignment="Center" Margin="244,80,0,0" Width="500"
           Height="70" HorizontalAlignment="Left" VerticalAlignment="Top"/>
    </Canvas>
</Window>

